{
  "manifest_version": 3,
  "name": "ThirdLayer Recorder",
  "version": "0.1.0",
  "description": "Capture browser events for workflow graph demos.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://localhost:8000/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
